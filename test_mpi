/*
 * Circuit Satisfiability, Version 1
 *
 * This MPI program determines whether a circuit is
 * satisfiable, that is, whether there is a combination of
 * inputs that causes the output of the circuit to be 1.
 * The particular circuit being tested is "wired" into the
 * logic of function 'check_circuit'. All combinations of
 * inputs that satisfy the circuit are printed.
 *
 * Programmed by Michael J. Quinn
 *
 * Last modification: 3 September 2002
 */

#include <mpi.h>
#include <stdio.h>

/* Macro para extraer el i-ésimo bit de un entero n */
#define EXTRACT_BIT(n,i) ((n&(1<<i))?1:0)

/* Declaración (prototipo) de la función encargada de evaluar el circuito */
void check_circuit (int id, int z) {
    int v[16]; /* Cada elemento representará un bit del número z */
    int i;

    /* Extrae los 16 bits del entero z y los guarda en el arreglo v */
    for (i = 0; i < 16; i++) {
        v[i] = EXTRACT_BIT(z, i);
    }

    /* Compuerta lógica gigante que define el circuito en sí */
    if ((v[0] || v[1]) && (!v[1] || v[3]) && (v[2] || v[3])
        && (v[3] || !v[4]) && (v[4] || !v[5])
        && (v[5] || !v[6]) && (v[5] || v[6])
        && (v[6] || !v[15]) && (v[7] || !v[8])
        && (!v[7] || !v[13]) && (v[8] || v[9])
        && (v[8] || !v[9]) && (!v[9] || !v[10])
        && (v[9] || v[11]) && (v[10] || v[11])
        && (v[12] || v[13]) && (v[13] || !v[14])
        && (v[14] || v[15])) {
        
        /* Si la combinación es válida (satisface el circuito), se imprime */
        printf ("%d) %d%d%d%d%d%d%d%d%d%d%d%d%d%d%d%d\n", id,
            v[0],v[1],v[2],v[3],v[4],v[5],v[6],v[7],v[8],v[9],
            v[10],v[11],v[12],v[13],v[14],v[15]);
        fflush (stdout);
    }
}

int main (int argc, char *argv[]) {
    int i;
    int id;  /* Identificador único del proceso (Rank) */
    int p;   /* Cantidad total de procesos activos */

    /* Inicialización del entorno de MPI */
    MPI_Init (&argc, &argv);
    MPI_Comm_rank (MPI_COMM_WORLD, &id);
    MPI_Comm_size (MPI_COMM_WORLD, &p);

    /* Bucle paralelo: reparte de forma intercalada las 65,536 combinaciones */
    for (i = id; i < 65536; i += p) {
        check_circuit (id, i);
    }

    /* Mensaje final de control por cada proceso */
    printf ("Process %d is done\n", id);
    fflush (stdout);
    
    /* Cierre del entorno de MPI */
    MPI_Finalize ();
    return 0;
}









